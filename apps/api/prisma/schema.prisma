generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String?
  analyses  Analysis[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Analysis {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  title        String?
  exerciseType String?
  notes        String?

  fileKey      String
  fileUrl      String
  fileName     String
  mimeType     String
  fileSize     Int

  status       AnalysisStatus @default(PENDING)
  resultJson   Json?
  errorMessage String?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
  @@index([status])
}